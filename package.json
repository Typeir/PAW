{
  "name": "paw-cli",
  "version": "0.1.0",
  "description": "Portable Agentic Workflows — quality gates, hooks, and agent memory for GitHub Copilot",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "paw": "dist/cli.mjs"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node build.mjs",
    "init": "node dist/cli.mjs init",
    "sync": "node dist/cli.mjs sync",
    "gates": "npx tsx pawGates.ts",
    "gates:changed": "npx tsx pawGates.ts --changed-only",
    "gates:staged": "npx tsx pawGates.ts --staged",
    "typecheck": "tsc --noEmit --project ../../.paw/tsconfig.json"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@github/copilot-sdk": "^0.2.2",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
